## ──────────────────────────────────────────────
## .gitignore for ASP.NET Core / C# project
## ──────────────────────────────────────────────

# Build output — generated by `dotnet build`, never commit these
bin/
obj/

# Visual Studio / VS Code settings
.vs/
.vscode/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet packages — restored automatically by `dotnet restore`
packages/
*.nupkg
.nuget/

# Publish output
publish/
**/publish/

# Secrets / environment config — NEVER commit these
appsettings.Production.json
*.env
secrets.json

# OS generated files
.DS_Store          # macOS
Thumbs.db          # Windows
desktop.ini

# Logs
*.log
logs/

# Rider / JetBrains IDE
.idea/
*.sln.iml
