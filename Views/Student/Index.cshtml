@* Tell Razor: this view receives a list of Student objects as its Model *@
@model IEnumerable<MyWebApp.Models.Student>

@{
    ViewData["Title"] = "Danh sách sinh viên";
}

<h2 class="mb-3">Danh sách sinh viên</h2>

@* Button to open the Create-Student form *@
@* asp-route="StudentAdd" matches the [Route(..., Name="StudentAdd")] in the controller *@
<a asp-route="StudentAdd" class="btn btn-primary mb-3">+ Create Student</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Mã</th>
            <th>Họ tên</th>
            <th>Ngày sinh</th>
            <th>Ngành</th>
            <th>Giới tính</th>
            <th>Hệ ĐT</th>
            <th>Địa chỉ</th>
            <th>Email</th>
        </tr>
    </thead>
    <tbody>
        @* Loop through every student in Model and render one <tr> per student *@
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Id</td>
                <td>@s.Name</td>
                <td>@s.DateOfBorth.ToString("dd/MM/yyyy")</td>

                @* Convert Branch enum → readable Vietnamese text *@
                <td>
                    @{
                        string branchText = "";
                        switch (s.Branch)
                        {
                            case MyWebApp.Models.Branch.IT: branchText = "CNTT";        break;
                            case MyWebApp.Models.Branch.BE: branchText = "Kinh tế";     break;
                            case MyWebApp.Models.Branch.CE: branchText = "Công trình";  break;
                            case MyWebApp.Models.Branch.EE: branchText = "Điện - Điện tử"; break;
                        }
                    }
                    @branchText
                </td>

                @* Convert Gender enum → Nam / Nữ *@
                <td>@(s.Gender == MyWebApp.Models.Gender.Male ? "Nam" : "Nữ")</td>

                @* Convert bool → Chính quy / Phi chính quy *@
                <td>@(s.IsRegular ? "Chính quy" : "Phi chính quy")</td>

                <td>@s.Address</td>
                <td>@s.Email</td>
            </tr>
        }
    </tbody>
</table>
